@namespace Zits.Ui

@* Presentational separator. Renders a chevron-right by default; override via ChildContent. *@
<li role="presentation" aria-hidden="true" @attributes="Attributes" class="@Cn.Class(Base, Cn.UserClass(Attributes))">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right">
            <path d="m9 18 6-6-6-6" />
        </svg>
    }
</li>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
    private const string Base = "[&>svg]:size-3.5";
}
