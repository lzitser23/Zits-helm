@namespace Zits.Ui
@using Navius.Primitives.Components.Button

@*
    Button. cva-style Variant/Size on the headless NaviusButton primitive (data-disabled,
    focusableWhenDisabled). The consumer's `class` is merged via Cn so overrides win cleanly.
*@

<NaviusButton Type="@Type" Disabled="Disabled" FocusableWhenDisabled="FocusableWhenDisabled"
              OnClick="OnClick" @attributes="Cn.Merge(Attributes, Base, VariantClass, SizeClass)">
    @ChildContent
</NaviusButton>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>default | destructive | outline | secondary | ghost | link</summary>
    [Parameter] public string Variant { get; set; } = "default";

    /// <summary>default | sm | lg | icon | icon-sm | icon-xs</summary>
    [Parameter] public string Size { get; set; } = "default";

    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Keep the button focusable while disabled (forwarded to the brain).</summary>
    [Parameter] public bool FocusableWhenDisabled { get; set; }

    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 data-[disabled]:pointer-events-none data-[disabled]:opacity-50";

    private string VariantClass => Variant switch
    {
        "destructive" => "bg-destructive text-destructive-foreground hover:bg-destructive/90",
        "outline" => "border border-input bg-background hover:bg-accent hover:text-accent-foreground",
        "secondary" => "bg-secondary text-secondary-foreground hover:bg-secondary/80",
        "ghost" => "hover:bg-accent hover:text-accent-foreground",
        "link" => "text-primary underline-offset-4 hover:underline",
        _ => "bg-primary text-primary-foreground hover:bg-primary/90",
    };

    private string SizeClass => Size switch
    {
        "sm" => "h-8 rounded-md px-3 text-xs",
        "lg" => "h-10 rounded-md px-8",
        "icon" => "h-9 w-9",
        "icon-sm" => "size-8 rounded-md",
        "icon-xs" => "size-7 rounded-md",
        _ => "h-9 px-4 py-2",
    };
}
