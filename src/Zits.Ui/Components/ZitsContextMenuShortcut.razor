@namespace Zits.Ui

@* A right-aligned keyboard shortcut hint inside a menu item. No brain part. *@
<span @attributes="Attributes" class="@Cn.Class(Base, Cn.UserClass(Attributes))">@ChildContent</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "ml-auto text-xs tracking-widest text-muted-foreground";
}
