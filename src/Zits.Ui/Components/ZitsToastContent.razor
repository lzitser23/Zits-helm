@namespace Zits.Ui
@using Navius.Primitives.Components.Toast

@*
    The stacking wrapper inside a toast (Base UI Toast.Content). Reads the C#-computed
    --toast-index / --toast-offset-y / --toast-frontmost-height vars + data-[expanded] /
    data-[behind] to turn the collapsed overlap into an expanded fan-out. The brain owns the
    vars; this is where the visual stack motion lives.
*@
<NaviusToastContent @attributes="Cn.Merge(Attributes, Base)">@ChildContent</NaviusToastContent>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    // Collapsed: behind toasts fade + scale down and tuck under the frontmost.
    // Expanded (viewport hover/focus): fan out by the cumulative offset at full scale.
    private const string Base =
        "flex w-full items-center justify-between gap-3 transition-all duration-200 " +
        "data-[behind]:opacity-0 data-[expanded]:opacity-100 " +
        "data-[expanded]:translate-y-[var(--toast-offset-y)]";
}
