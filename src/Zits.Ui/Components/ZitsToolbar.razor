@namespace Zits.Ui
@using Navius.Primitives.Components.Toolbar

@*
    A toolbar row over the Navius Toolbar brain (role=toolbar, single Tab stop, roving
    arrow-key focus). A bordered, rounded row of controls. Pass an
    aria-label through @attributes for an accessible name.
*@
<NaviusToolbar Orientation="Orientation"
               Loop="Loop"
               Dir="Dir"
               @attributes="Cn.Merge(Attributes, Base)">
    @ChildContent
</NaviusToolbar>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>horizontal | vertical</summary>
    [Parameter] public string Orientation { get; set; } = "horizontal";

    [Parameter] public bool Loop { get; set; } = true;
    [Parameter] public string? Dir { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "flex w-full items-center gap-1 rounded-md border border-input bg-background p-1 data-[orientation=vertical]:w-auto data-[orientation=vertical]:flex-col";
}
