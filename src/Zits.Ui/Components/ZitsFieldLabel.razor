@namespace Zits.Ui

@* The field's label. Composes the styled Label; turns destructive when the
   enclosing Field is marked data-[invalid]. *@
<ZitsLabel @attributes="Cn.Merge(Attributes, Base)">@ChildContent</ZitsLabel>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "group-data-[invalid=true]/field:text-destructive flex w-fit gap-2 leading-snug";
}
