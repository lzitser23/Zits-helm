@namespace Zits.Ui

@* Validation message for a Field. Renders nothing when there is no content. *@
@if (ChildContent is not null)
{
    <div role="alert" data-slot="field-error" @attributes="Attributes" class="@Css">@ChildContent</div>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    /// <summary>Opt in to a one-shot horizontal shake (Navius.Motion <c>motion-shake</c>) when the error appears. Inert unless the app links _content/Navius.Motion/navius-motion.css.</summary>
    [Parameter] public bool Shake { get; set; }

    private const string Base = "text-destructive text-sm font-normal";

    private string Css => Cn.Class(Base, Shake ? "motion-shake" : null, Cn.UserClass(Attributes));
}
