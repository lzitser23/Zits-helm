@namespace Zits.Ui
@using Navius.Primitives.Components.Toolbar

@*
    A focusable toolbar control (native <button>) over Navius Toolbar.Button. Inherits the
    toolbar's roving Tab order. Styled like a ghost/sm button.
*@
<NaviusToolbarButton Disabled="Disabled" @attributes="Cn.Merge(Attributes, Base)">
    @ChildContent
</NaviusToolbarButton>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Disabled { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "inline-flex h-8 items-center justify-center gap-2 whitespace-nowrap rounded-sm px-2.5 text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1 disabled:pointer-events-none disabled:opacity-50 [&_svg]:size-4 [&_svg]:shrink-0";
}
