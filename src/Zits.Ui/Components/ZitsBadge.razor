@namespace Zits.Ui

<span @attributes="Attributes" class="@Css">@ChildContent</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>default | secondary | destructive | outline</summary>
    [Parameter] public string Variant { get; set; } = "default";

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2";

    private string VariantClass => Variant switch
    {
        "secondary" => "border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80",
        "destructive" => "border-transparent bg-destructive text-destructive-foreground hover:bg-destructive/80",
        "outline" => "text-foreground",
        _ => "border-transparent bg-primary text-primary-foreground hover:bg-primary/80",
    };

    private string Css => Cn.Class(Base, VariantClass, Cn.UserClass(Attributes));
}
