@namespace Zits.Ui

@* Stacks consecutive messages from the same sender. Render an empty ZitsMessageAvatar
   on earlier messages to keep alignment with the avatar on the last one. *@
<div data-slot="message-group" @attributes="Attributes" class="@Css">@ChildContent</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "flex min-w-0 flex-col gap-2";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));
}
