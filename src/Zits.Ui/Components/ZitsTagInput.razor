@namespace Zits.Ui
@using Navius.Primitives.Components.TagInput

@*
    TagInput = the headless NaviusTagInput + a pill/chip skin. Controlled/uncontrolled is owned
    here (ZitsCalendar discipline): a _tags mirror seeded from DefaultValue, only adopting Value
    when supplied. The chips are looped here (the brain has no auto-chips part); each renders the
    brain NaviusTag/NaviusTagRemove so removal + highlight run through the brain unchanged.
*@

<NaviusTagInput Value="_tags"
                ValueChanged="OnValueChangedAsync"
                Delimiters="Delimiters"
                AllowDuplicates="AllowDuplicates"
                MaxTags="MaxTags"
                Validate="Validate"
                Transform="Transform"
                AddOnBlur="AddOnBlur"
                Disabled="Disabled"
                OnAdd="OnAdd"
                OnRemove="OnRemove"
                OnInvalid="OnInvalid"
                @attributes="Cn.Merge(Attributes, Root)">
    <NaviusTagInputList class="contents">
        @for (var i = 0; i < _tags.Count; i++)
        {
            var index = i;
            var tag = _tags[i];
            <NaviusTag Value="@tag" Index="index" @key="tag" class="@Chip">
                @tag
                <NaviusTagRemove aria-label="@($"Remove {tag}")" class="@Remove">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg>
                </NaviusTagRemove>
            </NaviusTag>
        }
    </NaviusTagInputList>
    <NaviusTagInputField Placeholder="@Placeholder" class="@Field" />
</NaviusTagInput>

@code {
    /// <summary>Controlled tag list. Use <c>@bind-Value</c>.</summary>
    [Parameter] public IList<string>? Value { get; set; }

    [Parameter] public EventCallback<IList<string>> ValueChanged { get; set; }

    /// <summary>Uncontrolled initial tags.</summary>
    [Parameter] public IList<string>? DefaultValue { get; set; }

    [Parameter] public string? Placeholder { get; set; }

    [Parameter] public IReadOnlyList<TagDelimiter>? Delimiters { get; set; }

    [Parameter] public bool AllowDuplicates { get; set; }

    [Parameter] public int? MaxTags { get; set; }

    [Parameter] public Func<string, bool>? Validate { get; set; }

    [Parameter] public Func<string, string>? Transform { get; set; }

    [Parameter] public bool AddOnBlur { get; set; }

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public EventCallback<string> OnAdd { get; set; }

    [Parameter] public EventCallback<string> OnRemove { get; set; }

    [Parameter] public EventCallback<string> OnInvalid { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private List<string> _tags = new();
    private bool _valueSet;
    private bool _initialized;

    private const string Root =
        "flex min-h-9 w-full flex-wrap items-center gap-1 rounded-md border border-input bg-transparent p-1 text-sm shadow-sm transition-colors focus-within:ring-1 focus-within:ring-ring data-[disabled]:cursor-not-allowed data-[disabled]:opacity-50";

    private const string Chip =
        "inline-flex items-center gap-1 rounded bg-secondary px-2 py-0.5 text-xs font-medium text-secondary-foreground outline-none data-[highlighted]:ring-1 data-[highlighted]:ring-ring";

    private const string Remove =
        "inline-flex items-center rounded-sm leading-none text-muted-foreground hover:text-foreground";

    private const string Field =
        "h-7 min-w-[6rem] flex-1 bg-transparent px-1 text-sm outline-none placeholder:text-muted-foreground disabled:cursor-not-allowed";

    public override Task SetParametersAsync(ParameterView parameters)
    {
        _valueSet = parameters.TryGetValue<IList<string>?>(nameof(Value), out _);
        return base.SetParametersAsync(parameters);
    }

    protected override void OnParametersSet()
    {
        if (!_initialized)
        {
            _tags = new List<string>((_valueSet ? Value : DefaultValue) ?? Array.Empty<string>());
            _initialized = true;
            return;
        }

        if (_valueSet)
        {
            _tags = new List<string>(Value ?? Array.Empty<string>());
        }
    }

    private async Task OnValueChangedAsync(IList<string> v)
    {
        if (!_valueSet)
        {
            _tags = new List<string>(v);
        }

        await ValueChanged.InvokeAsync(v);
    }
}
