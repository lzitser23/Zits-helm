@namespace Zits.Ui

@* Styled wrapper over the Navius Separator primitive (role/aria-orientation). *@
<NaviusSeparator Orientation="@Orientation"
                 @attributes="Cn.Merge(Attributes, Base, OrientationClass)" />

@code {
    /// <summary>horizontal | vertical</summary>
    [Parameter] public string Orientation { get; set; } = "horizontal";

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "shrink-0 bg-border";

    private string OrientationClass =>
        Orientation == "vertical" ? "h-full w-px" : "h-px w-full";
}
