@namespace Zits.Ui

@* Wraps the control(s) inside a Field. *@
<div data-slot="field-content" @attributes="Attributes" class="@Css">@ChildContent</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "flex flex-1 flex-col gap-1.5 leading-snug";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));
}
