@namespace Zits.Ui

@* Timeline content, the text block beside the rail (time / title / description). *@

<div data-navius-timeline-content @attributes="Attributes" class="@ContentClass">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "flex flex-1 flex-col gap-0.5 pb-6";

    private string ContentClass => Cn.Class(Base, Cn.UserClass(Attributes));
}
