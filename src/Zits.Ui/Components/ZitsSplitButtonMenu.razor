@namespace Zits.Ui

@* The dropdown surface: the styled ZitsMenuContent (Portal > Positioner > Popup). Fill it with ZitsMenuItem. *@

<ZitsMenuContent Side="@Side" Align="@Align" SideOffset="SideOffset" @attributes="Attributes">
    @ChildContent
</ZitsMenuContent>

@code {
    [Parameter] public string Side { get; set; } = "bottom";

    [Parameter] public string Align { get; set; } = "end";

    [Parameter] public double SideOffset { get; set; } = 4;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
