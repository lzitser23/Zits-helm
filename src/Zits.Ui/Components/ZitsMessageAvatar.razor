@namespace Zits.Ui

@* Avatar slot, bottom-aligned to the message; shifts up when a MessageFooter exists so
   it stays aligned with the bubble instead of the footer. *@
<div data-slot="message-avatar" @attributes="Attributes" class="@Css">@ChildContent</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "flex w-fit min-w-8 shrink-0 items-center justify-center self-end overflow-hidden rounded-full bg-muted group-has-data-[slot=message-footer]/message:-translate-y-8";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));
}
