@namespace Zits.Ui
@using Navius.Primitives.Components.NavigationMenu

@*
    Content panel over the Navius primitive. Reproduces the directional enter motion driven
    by the brain's data-activation-direction (left | right | up | down) — the Base UI
    replacement for the former data-motion. Positioning (side/align/offset) now lives on the
    Positioner, and dismissal callbacks on the Popup, so this wrapper is purely the panel.
    In Viewport mode the panel teleports into the shared viewport; the md: width rules apply
    once it sits inside that container.
*@

<NaviusNavigationMenuContent ForceMount="ForceMount" @attributes="Cn.Merge(Attributes, Base)">@ChildContent</NaviusNavigationMenuContent>

@code {
    [Parameter] public bool ForceMount { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "left-0 top-0 w-full data-[activation-direction]:animate-in data-[activation-direction]:fade-in " +
        "data-[activation-direction=right]:slide-in-from-right-52 data-[activation-direction=left]:slide-in-from-left-52 " +
        "data-[activation-direction=down]:slide-in-from-top-52 data-[activation-direction=up]:slide-in-from-bottom-52 " +
        "md:absolute md:w-auto";
}
