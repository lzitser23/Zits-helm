@namespace Zits.Ui
@using Navius.Primitives.Components.OneTimePasswordField

@* Styled one-time-password field over the Navius OneTimePasswordField primitive (role=group,
   per-cell inputs, paste distribution, keyboard nav). Compose ZitsInputOtpGroup / ZitsInputOtpSlot /
   ZitsInputOtpSeparator inside. *@
<NaviusOneTimePasswordField Length="Length" Value="@Value" ValueChanged="ValueChanged"
                            DefaultValue="@DefaultValue" Disabled="Disabled" ReadOnly="ReadOnly"
                            InputMode="@InputMode" ValidationType="@ValidationType" Type="@Type"
                            Orientation="@Orientation" Placeholder="@Placeholder" AutoFocus="AutoFocus"
                            Name="@Name" Form="@Form" AutoSubmit="AutoSubmit"
                            OnAutoSubmit="OnAutoSubmit" OnComplete="OnComplete"
                            @attributes="Cn.Merge(Attributes, Base)">
    @ChildContent
</NaviusOneTimePasswordField>

@code {
    [Parameter] public int Length { get; set; } = 6;
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string? DefaultValue { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public string InputMode { get; set; } = "numeric";
    [Parameter] public string ValidationType { get; set; } = "numeric";
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public string Orientation { get; set; } = "horizontal";
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool AutoFocus { get; set; }
    [Parameter] public string? Name { get; set; }
    [Parameter] public string? Form { get; set; }
    [Parameter] public bool AutoSubmit { get; set; }
    [Parameter] public EventCallback<string> OnAutoSubmit { get; set; }
    [Parameter] public EventCallback<string> OnComplete { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "flex items-center gap-2 has-[:disabled]:opacity-50";
}
