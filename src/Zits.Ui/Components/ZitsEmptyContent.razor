@namespace Zits.Ui
<div data-slot="empty-content" @attributes="Attributes" class="@Cn.Class(Base, Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    private const string Base = "flex w-full max-w-sm min-w-0 flex-col items-center gap-4 text-sm text-balance";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
