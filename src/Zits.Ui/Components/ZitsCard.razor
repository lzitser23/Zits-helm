@namespace Zits.Ui
<div @attributes="Attributes" class="@Cn.Class("rounded-xl border bg-card text-card-foreground shadow", Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
