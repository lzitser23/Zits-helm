@namespace Zits.Ui
<NaviusDialogDescription @attributes="Cn.Merge(Attributes, Base)">@ChildContent</NaviusDialogDescription>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
    private const string Base = "text-sm text-muted-foreground";
}
