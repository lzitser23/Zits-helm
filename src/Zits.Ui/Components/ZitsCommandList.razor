@namespace Zits.Ui

@* Scrollable list region holding groups, items, and the empty state. *@

<div @attributes="Attributes" class="@Css" role="listbox">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "max-h-[300px] overflow-y-auto overflow-x-hidden";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));
}
