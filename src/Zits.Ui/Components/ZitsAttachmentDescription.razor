@namespace Zits.Ui

@* Type / size / status metadata. Keep the failure reason here when state is error. *@
<span data-slot="attachment-description" @attributes="Attributes" class="@Css">@ChildContent</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "mt-0.5 block max-w-full min-w-0 truncate text-xs text-muted-foreground group-data-[state=error]/attachment:text-destructive/80";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));
}
