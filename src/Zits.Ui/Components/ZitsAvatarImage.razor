@namespace Zits.Ui

@* The avatar image; hidden until it loads, removed on error so the fallback shows. *@
<NaviusAvatarImage Src="@Src" OnLoadingStatusChange="OnLoadingStatusChange"
                   @attributes="Cn.Merge(Attributes, Base)" />

@code {
    [Parameter] public string? Src { get; set; }
    [Parameter] public EventCallback<string> OnLoadingStatusChange { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "aspect-square h-full w-full";
}
