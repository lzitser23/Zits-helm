@namespace Zits.Ui
<div @attributes="Attributes" class="@Cn.Class("flex flex-col-reverse sm:flex-row sm:justify-end sm:space-x-2", Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
