@namespace Zits.Ui
@using Navius.Primitives.Components.Toolbar

@*
    A non-focusable divider between groups of toolbar items over Navius Toolbar.Separator.
    Renders perpendicular to the toolbar axis.
*@
<NaviusToolbarSeparator @attributes="Cn.Merge(Attributes, Base)" />

@code {
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "shrink-0 bg-border data-[orientation=vertical]:mx-1 data-[orientation=vertical]:h-6 data-[orientation=vertical]:w-px data-[orientation=horizontal]:my-1 data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-full";
}
