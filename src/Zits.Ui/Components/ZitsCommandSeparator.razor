@namespace Zits.Ui

@* A divider between command groups. aria-hidden, not role="separator": a separator
   is not a permitted child of the role="listbox" list, so it stays visual-only. *@

<div @attributes="Attributes" class="@Css" aria-hidden="true"></div>

@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "-mx-1 h-px bg-border";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));
}
