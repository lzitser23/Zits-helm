@namespace Zits.Ui
@using Navius.Primitives.Components.Menu
@* The button that opens the menu. Unstyled by default so it composes with ZitsButton or any trigger. *@
<NaviusMenuTrigger Disabled="Disabled" @attributes="Attributes">@ChildContent</NaviusMenuTrigger>
@code {
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
