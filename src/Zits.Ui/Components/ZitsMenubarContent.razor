@namespace Zits.Ui
@using Navius.Primitives.Components.Menubar
@* The styled menu surface (Base UI Portal > Positioner > Popup), positioned by the engine (side=bottom, align=start, the defaults). *@
<NaviusMenubarPortal>
    <NaviusMenubarPositioner Side="@Side" Align="@Align" SideOffset="SideOffset" AlignOffset="AlignOffset">
        <NaviusMenubarPopup Loop="Loop" @attributes="Cn.Merge(Attributes, Base)">
            @ChildContent
        </NaviusMenubarPopup>
    </NaviusMenubarPositioner>
</NaviusMenubarPortal>
@code {
    [Parameter] public string Side { get; set; } = "bottom";
    [Parameter] public string Align { get; set; } = "start";
    [Parameter] public double SideOffset { get; set; } = 8;
    [Parameter] public double AlignOffset { get; set; } = -4;
    [Parameter] public bool Loop { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
    private const string Base =
        "z-50 min-w-[12rem] overflow-hidden rounded-md border bg-popover p-1 text-popover-foreground shadow-md data-[open]:animate-in data-[closed]:fade-out-0 data-[open]:fade-in-0 data-[closed]:zoom-out-95 data-[open]:zoom-in-95 data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2";
}
