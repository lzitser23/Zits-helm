@namespace Zits.Ui
@using Navius.Primitives.Components.Menubar
@using Navius.Primitives.Common
<NaviusMenubarItem OnSelect="OnSelect" Disabled="Disabled" TextValue="@TextValue"
                   @attributes="Cn.Merge(Attributes, Base, InsetClass)">@ChildContent</NaviusMenubarItem>
@code {
    [Parameter] public EventCallback<NaviusSelectEventArgs> OnSelect { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Inset { get; set; }
    [Parameter] public string? TextValue { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
    private const string Base =
        "relative flex cursor-default select-none items-center rounded-sm px-2 py-1.5 text-sm outline-none focus:bg-accent focus:text-accent-foreground data-[disabled]:pointer-events-none data-[disabled]:opacity-50";
    private string? InsetClass => Inset ? "pl-8" : null;
}
