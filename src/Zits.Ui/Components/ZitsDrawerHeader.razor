@namespace Zits.Ui
<div @attributes="Attributes" class="@Cn.Class("grid gap-1.5 p-4 text-center sm:text-left", Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
