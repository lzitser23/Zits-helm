@namespace Zits.Ui
@* The element that opens the tooltip on hover/focus. Forwards every attribute to the brain trigger. *@
<NaviusTooltipTrigger @attributes="Attributes">@ChildContent</NaviusTooltipTrigger>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
