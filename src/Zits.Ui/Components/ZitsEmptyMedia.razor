@namespace Zits.Ui
<div data-slot="empty-icon" data-variant="@Variant" @attributes="Attributes" class="@Cn.Class(Base, VariantClass, Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    private const string Base = "flex shrink-0 items-center justify-center mb-2 [&_svg]:pointer-events-none [&_svg]:shrink-0";

    /// <summary>"default" or "icon". The icon variant renders a muted rounded tile sized for an icon.</summary>
    [Parameter] public string Variant { get; set; } = "default";

    private string VariantClass => Variant switch
    {
        "icon" => "bg-muted text-foreground flex size-10 shrink-0 items-center justify-center rounded-lg [&_svg:not([class*='size-'])]:size-6",
        _ => "bg-transparent",
    };

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
