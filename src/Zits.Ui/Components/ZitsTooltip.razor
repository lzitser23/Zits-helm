@namespace Zits.Ui
@using Navius.Primitives.Components.Tooltip
@*
    Styled tooltip root over the Navius Tooltip primitive (open-state + show/hide
    timing, portal, collision-aware positioning). The root wraps its
    own provider with a 0ms delay so a lone <ZitsTooltip> works without an explicit
    <ZitsTooltipProvider>.
    Open is forwarded to the primitive ONLY when the consumer set it, so the uncontrolled
    DefaultOpen path stays live (the always-controlled wart fix).
*@
<NaviusTooltipProvider DelayDuration="DelayDuration">
    <NaviusTooltip OpenChanged="OpenChanged" DefaultOpen="DefaultOpen"
                   DelayDuration="DelayDuration" @attributes="Forwarded">@ChildContent</NaviusTooltip>
</NaviusTooltipProvider>
@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public bool DefaultOpen { get; set; }
    [Parameter] public int DelayDuration { get; set; } = 0;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _openSet;

    public override Task SetParametersAsync(ParameterView parameters)
    {
        _openSet = parameters.TryGetValue<bool>(nameof(Open), out _);
        return base.SetParametersAsync(parameters);
    }

    private IReadOnlyDictionary<string, object> Forwarded
    {
        get
        {
            var merged = new Dictionary<string, object>();
            if (_openSet)
            {
                merged["Open"] = Open;
            }

            return merged;
        }
    }
}
