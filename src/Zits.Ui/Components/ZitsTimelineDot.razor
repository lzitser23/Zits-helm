@namespace Zits.Ui

@*
    Timeline dot, the node marker on the rail. Variant sets the ink; an optional ChildContent
    slot holds a custom icon (a small glyph sizes to the dot). Presentational only.
*@

<span data-navius-timeline-dot data-variant="@Variant" @attributes="Attributes" class="@DotClass">
    @ChildContent
</span>

@code {
    /// <summary>default | outline | secondary | destructive | muted.</summary>
    [Parameter] public string Variant { get; set; } = "default";

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "z-10 flex size-3 shrink-0 items-center justify-center rounded-full [&>svg]:size-2.5";

    private string VariantClass => Variant switch
    {
        "outline" => "border-2 border-primary bg-background",
        "secondary" => "bg-secondary text-secondary-foreground",
        "destructive" => "bg-destructive text-destructive-foreground",
        "muted" => "bg-muted text-muted-foreground",
        _ => "bg-primary text-primary-foreground",
    };

    private string DotClass => Cn.Class(Base, VariantClass, Cn.UserClass(Attributes));
}
