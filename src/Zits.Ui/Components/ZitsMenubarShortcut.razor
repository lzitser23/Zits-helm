@namespace Zits.Ui
@* A right-aligned keyboard-shortcut hint. Styled-only, no brain part. *@
<span @attributes="Attributes" class="@Css">@ChildContent</span>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
    private const string Base = "ml-auto text-xs tracking-widest text-muted-foreground";
    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));
}
