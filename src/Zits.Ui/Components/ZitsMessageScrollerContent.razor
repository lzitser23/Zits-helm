@namespace Zits.Ui
@using Navius.Primitives.Components.MessageScroller

@*
    The transcript container (= shadcn MessageScroller.Content): a live region whose direct
    children are MessageScroller items. The engine sizes an internal spacer to make room for
    an anchored turn near the top; style it with SpacerClass when it should be visible.
*@

<NaviusMessageScrollerContent SpacerClass="@SpacerClass"
                              data-slot="message-scroller-content"
                              @attributes="Cn.Merge(Attributes, Base)">
    @ChildContent
</NaviusMessageScrollerContent>

@code {
    /// <summary>Class for the internal spacer element that makes room for anchored rows.</summary>
    [Parameter] public string? SpacerClass { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "flex h-max min-h-full flex-col gap-6";
}
