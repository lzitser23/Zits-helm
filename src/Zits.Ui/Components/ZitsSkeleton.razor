@namespace Zits.Ui

<div @attributes="Attributes" class="@Css">@ChildContent</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    /// <summary>Swap the pulse for a shimmer sweep (Navius.Motion <c>motion-shimmer</c>). Inert unless the app links _content/Navius.Motion/navius-motion.css.</summary>
    [Parameter] public bool Shimmer { get; set; }

    private const string Base = "rounded-md bg-muted";

    private string Css => Cn.Class(Shimmer ? "motion-shimmer" : "animate-pulse", Base, Cn.UserClass(Attributes));
}
