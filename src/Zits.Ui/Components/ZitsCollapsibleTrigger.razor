@namespace Zits.Ui
@using Navius.Primitives.Components.Collapsible

@* The trigger toggles the panel. The primitive trigger is re-exported unstyled;
   consumers compose it (e.g. asChild over a Button) or pass classes, so we only
   forward attributes + merge any consumer class. *@
<NaviusCollapsibleTrigger @attributes="Attributes">@ChildContent</NaviusCollapsibleTrigger>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
