@namespace Zits.Ui

@* Wraps the header, the bubble surface and the footer for one message. *@
<div data-slot="message-content" @attributes="Attributes" class="@Css">@ChildContent</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "flex w-full min-w-0 flex-col gap-2.5 wrap-break-word group-data-[align=end]/message:*:data-slot:self-end";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));
}
