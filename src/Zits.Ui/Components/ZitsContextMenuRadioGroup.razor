@namespace Zits.Ui
@using Navius.Primitives.Components.ContextMenu

@* A group of mutually-exclusive radio items. *@
<NaviusContextMenuRadioGroup Value="@Value" ValueChanged="ValueChanged" DefaultValue="@DefaultValue"
                             @attributes="Attributes">@ChildContent</NaviusContextMenuRadioGroup>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? DefaultValue { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
