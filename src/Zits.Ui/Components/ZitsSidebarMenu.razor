@namespace Zits.Ui
@* Sidebar menu — the <ul> list of items. *@
<ul data-sidebar="menu" @attributes="Attributes" class="@Cn.Class("flex w-full min-w-0 flex-col gap-1 p-2", Cn.UserClass(Attributes))">@ChildContent</ul>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
