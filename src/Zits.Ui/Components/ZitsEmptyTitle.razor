@namespace Zits.Ui
<div data-slot="empty-title" @attributes="Attributes" class="@Cn.Class(Base, Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    private const string Base = "text-lg font-medium tracking-tight";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
