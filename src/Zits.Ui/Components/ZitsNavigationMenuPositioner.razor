@namespace Zits.Ui
@using Navius.Primitives.Components.NavigationMenu

@*
    Thin Positioner over the Navius primitive. Publishes placement (side / align / offset)
    into the context; the Popup renders the positioning div. Base UI centres the panel
    under the active trigger (bottom / center).
*@

<NaviusNavigationMenuPositioner Side="@Side" Align="@Align" SideOffset="SideOffset" @attributes="Attributes">
    @ChildContent
</NaviusNavigationMenuPositioner>

@code {
    [Parameter] public string? Side { get; set; }
    [Parameter] public string? Align { get; set; }
    [Parameter] public double SideOffset { get; set; } = 8;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
