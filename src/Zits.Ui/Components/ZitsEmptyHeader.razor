@namespace Zits.Ui
<div data-slot="empty-header" @attributes="Attributes" class="@Cn.Class(Base, Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    private const string Base = "flex max-w-sm flex-col items-center gap-2 text-center";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
