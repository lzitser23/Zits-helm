@namespace Zits.Ui
@using Navius.Primitives.Components.ContextMenu

@* The styled menu surface (Base UI Portal > Positioner > Popup), positioned by the engine at the cursor point. *@
<NaviusContextMenuPortal>
    <NaviusContextMenuPositioner Side="right" Align="start">
        <NaviusContextMenuPopup @attributes="Cn.Merge(Attributes, Base)">
            @ChildContent
        </NaviusContextMenuPopup>
    </NaviusContextMenuPositioner>
</NaviusContextMenuPortal>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "z-50 max-h-[--available-height] min-w-[8rem] overflow-y-auto overflow-x-hidden rounded-md border bg-popover p-1 text-popover-foreground shadow-md data-[open]:animate-in data-[closed]:animate-out data-[closed]:fade-out-0 data-[open]:fade-in-0 data-[closed]:zoom-out-95 data-[open]:zoom-in-95 data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2";
}
