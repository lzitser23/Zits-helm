@namespace Zits.Ui
@using Navius.Primitives.Components.Menubar
<NaviusMenubarLabel @attributes="Cn.Merge(Attributes, Base, InsetClass)">@ChildContent</NaviusMenubarLabel>
@code {
    [Parameter] public bool Inset { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
    private const string Base = "px-2 py-1.5 text-sm font-semibold";
    private string? InsetClass => Inset ? "pl-8" : null;
}
