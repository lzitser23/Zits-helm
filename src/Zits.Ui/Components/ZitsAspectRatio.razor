@namespace Zits.Ui

@* Styled pass-through over the Navius AspectRatio primitive. This wrapper
   adds no classes of its own — it re-exports the brain's Root — so it forwards
   the ratio and every consumer attribute (including class) straight through. *@
<NaviusAspectRatio Ratio="Ratio" @attributes="Attributes">
    @ChildContent
</NaviusAspectRatio>

@code {
    [Parameter] public double Ratio { get; set; } = 1.0;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
