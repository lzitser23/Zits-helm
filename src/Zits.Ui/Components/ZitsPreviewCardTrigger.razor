@namespace Zits.Ui
@using Navius.Primitives.Components.PreviewCard
@* Anchor that opens the preview card on hover/focus. Renders the Navius trigger (an <a>) so it stays focusable. *@
<NaviusPreviewCardTrigger @attributes="Attributes">@ChildContent</NaviusPreviewCardTrigger>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
