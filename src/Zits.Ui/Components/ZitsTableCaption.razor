@namespace Zits.Ui
<caption @attributes="Attributes" class="@Cn.Class("mt-4 text-sm text-muted-foreground", Cn.UserClass(Attributes))">@ChildContent</caption>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
