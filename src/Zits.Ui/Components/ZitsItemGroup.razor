@namespace Zits.Ui
<div role="list" @attributes="Attributes" class="@Cn.Class("group/item-group flex flex-col", Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
