@namespace Zits.Ui
<div @attributes="Attributes" class="@Cn.Class("flex flex-col space-y-2 text-center sm:text-left", Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
