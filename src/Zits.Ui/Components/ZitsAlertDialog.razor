@namespace Zits.Ui
@* Styled alert dialog over the Navius AlertDialog primitive (focus trap, scroll lock, portal; outside-click never closes). *@
<NaviusAlertDialog Open="Open" OpenChanged="OpenChanged" DefaultOpen="DefaultOpen">@ChildContent</NaviusAlertDialog>
@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public bool DefaultOpen { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
