@namespace Zits.Ui
@using Navius.Primitives.Components.Rating

@*
    Styled star rating over the Navius Rating primitive (role=radiogroup, roving
    tabindex, APG radio keyboard). Each star renders a muted base glyph with a
    primary fill clipped by data-state (full/half/empty), so whole and half values
    (AllowHalf) both read. Controlled via @bind-Value or uncontrolled via
    DefaultValue: Value is forwarded to the primitive ONLY when the consumer set
    it, so the uncontrolled DefaultValue path stays live (the always-controlled
    wart fix).
*@

<NaviusRating DefaultValue="DefaultValue"
              ValueChanged="ValueChanged"
              Max="Max"
              AllowHalf="AllowHalf"
              AllowClear="AllowClear"
              ReadOnly="ReadOnly"
              Disabled="Disabled"
              Required="Required"
              Invalid="Invalid"
              Name="@Name"
              Label="Label"
              Dir="@Dir"
              @attributes="Forwarded">
    @for (var i = 0; i < Max; i++)
    {
        <NaviusRatingItem class="@ItemClass">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="absolute inset-0 h-full w-full fill-muted-foreground/30">
                <path d="@StarPath" />
            </svg>
            <span aria-hidden="true"
                  class="pointer-events-none absolute inset-y-0 left-0 overflow-hidden group-data-[state=empty]:w-0 group-data-[state=half]:w-1/2 group-data-[state=full]:w-full">
                <svg viewBox="0 0 24 24" class="h-full w-6 shrink-0 fill-primary">
                    <path d="@StarPath" />
                </svg>
            </span>
        </NaviusRatingItem>
    }
</NaviusRating>

@code {
    /// <summary>Controlled value (null = unrated). Bind with <c>@bind-Value</c>.</summary>
    [Parameter] public decimal? Value { get; set; }
    [Parameter] public EventCallback<decimal?> ValueChanged { get; set; }
    /// <summary>Uncontrolled initial value.</summary>
    [Parameter] public decimal? DefaultValue { get; set; }
    [Parameter] public int Max { get; set; } = 5;
    [Parameter] public bool AllowHalf { get; set; }
    [Parameter] public bool AllowClear { get; set; } = true;
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Invalid { get; set; }
    [Parameter] public string? Name { get; set; }
    [Parameter] public Func<decimal, string>? Label { get; set; }
    [Parameter] public string? Dir { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private bool _valueSet;

    private const string Root =
        "inline-flex items-center gap-0.5 data-[disabled]:pointer-events-none data-[disabled]:opacity-50";

    private const string ItemClass =
        "group relative inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-sm outline-none transition-transform hover:scale-110 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1 focus-visible:ring-offset-background data-[readonly]:cursor-default data-[readonly]:hover:scale-100 cursor-pointer";

    private const string StarPath =
        "M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z";

    public override Task SetParametersAsync(ParameterView parameters)
    {
        // Controlled-ness = whether Value was supplied this render (mirrors NaviusInput);
        // forward Value only when set so DefaultValue drives the uncontrolled path.
        _valueSet = parameters.TryGetValue<decimal?>(nameof(Value), out _);
        return base.SetParametersAsync(parameters);
    }

    private IReadOnlyDictionary<string, object> Forwarded
    {
        get
        {
            var merged = new Dictionary<string, object>(Cn.Merge(Attributes, Root));
            if (_valueSet)
            {
                merged["Value"] = Value!;
            }

            return merged;
        }
    }
}
