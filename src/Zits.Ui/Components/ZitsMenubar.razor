@namespace Zits.Ui
@using Navius.Primitives.Components.Menubar
@* Styled menubar over the Navius Menubar primitive (roving triggers, follow-focus). *@
<NaviusMenubar Value="@Value" ValueChanged="ValueChanged" DefaultValue="@DefaultValue"
               Orientation="@Orientation" Dir="@Dir" Loop="Loop"
               @attributes="Cn.Merge(Attributes, Base)">@ChildContent</NaviusMenubar>
@code {
    private const string Base =
        "flex h-10 items-center space-x-1 rounded-md border bg-background p-1";
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? DefaultValue { get; set; }
    [Parameter] public string Orientation { get; set; } = "horizontal";
    [Parameter] public string? Dir { get; set; }
    [Parameter] public bool Loop { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
