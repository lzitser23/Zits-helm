@namespace Zits.Ui
@* Sidebar header — top region (logo/title). *@
<div data-sidebar="header" @attributes="Attributes" class="@Cn.Class("flex flex-col gap-2 p-2", Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
