@namespace Zits.Ui

@* Styled radio button over the Navius RadioGroupItem primitive. The indicator
   renders the filled dot (lucide Circle) only when this item is checked. *@
<NaviusRadioGroupItem Value="@Value" Disabled="Disabled" Required="Required" ReadOnly="ReadOnly"
                      @attributes="Cn.Merge(Attributes, Base)">
    <NaviusRadioGroupIndicator class="@Indicator">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
             fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round"
             stroke-linejoin="round" class="@Icon" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
        </svg>
    </NaviusRadioGroupIndicator>
</NaviusRadioGroupItem>

@code {
    private const string Base =
        "border-input text-primary focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive dark:bg-input/30 aspect-square size-4 shrink-0 rounded-full border shadow-xs transition-[color,box-shadow] outline-none focus-visible:ring-[3px] disabled:cursor-not-allowed disabled:opacity-50";

    private const string Indicator = "relative flex items-center justify-center";

    private const string Icon = "fill-primary absolute top-1/2 left-1/2 size-2 -translate-x-1/2 -translate-y-1/2";

    [Parameter] public string Value { get; set; } = "";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool ReadOnly { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }
}
