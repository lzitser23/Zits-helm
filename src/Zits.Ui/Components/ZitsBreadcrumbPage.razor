@namespace Zits.Ui
<span role="link" aria-disabled="true" aria-current="page" @attributes="Attributes" class="@Cn.Class(Base, Cn.UserClass(Attributes))">@ChildContent</span>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
    private const string Base = "font-normal text-foreground";
}
