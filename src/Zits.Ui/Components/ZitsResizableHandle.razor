@namespace Zits.Ui
@inject IJSRuntime JS
@implements IAsyncDisposable

@*
    The draggable bar between two panels. Pure Blazor pointer events: on pointer-down
    we measure the group's main-axis pixel size once (one getRect) and render a
    full-window transparent overlay that captures every subsequent pointermove/up —
    the Blazor-native stand-in for pointer capture, so the drag survives the pointer
    leaving the 1px bar. Each move converts the pixel delta to a percentage and asks
    the group to re-balance the two adjacent panels' flex-basis in C#. No JS drag loop.
    Optional centred grip via WithHandle.
*@

<div data-panel-resize-handle
     data-panel-group-direction="@(IsVertical ? "vertical" : "horizontal")"
     data-resize-handle-active="@(_dragging ? "pointer" : null)"
     role="separator"
     tabindex="0"
     @onpointerdown="OnPointerDown"
     @onkeydown="OnKeyDown"
     @attributes="Attributes"
     class="@Css">
    @if (WithHandle)
    {
        <div class="z-10 flex h-4 w-3 items-center justify-center rounded-sm border bg-border">
            @* GripVertical icon (lucide), the optional WithHandle grip. *@
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 stroke-linejoin="round" class="h-2.5 w-2.5">
                <circle cx="9" cy="12" r="1" />
                <circle cx="9" cy="5" r="1" />
                <circle cx="9" cy="19" r="1" />
                <circle cx="15" cy="12" r="1" />
                <circle cx="15" cy="5" r="1" />
                <circle cx="15" cy="19" r="1" />
            </svg>
        </div>
    }
</div>

@if (_dragging)
{
    @* Transparent capture surface: while dragging, every pointer event lands here so
       the gesture continues past the thin bar. Pure Blazor — replaces pointer capture. *@
    <div class="fixed inset-0 z-50 @(IsVertical ? "cursor-row-resize" : "cursor-col-resize")"
         style="touch-action:none;"
         @onpointermove="OnPointerMove"
         @onpointerup="OnPointerUp"
         @onpointercancel="OnPointerUp"
         @onpointerleave="OnPointerUp"></div>
}

@code {
    /// <summary>Show the centred grip affordance.</summary>
    [Parameter] public bool WithHandle { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    [CascadingParameter] private ZitsResizablePanelGroup? Group { get; set; }

    private bool _dragging;
    private double _last;        // last pointer position on the main axis (px)
    private double _groupPx;     // group main-axis size in px (px per 100%)
    private ZitsResizablePanel? _before;
    private ZitsResizablePanel? _after;
    private IJSObjectReference? _module;

    private bool IsVertical => Group?.IsVertical == true;

    protected override void OnInitialized() => Group?.RegisterHandle(this);

    private async Task OnPointerDown(PointerEventArgs e)
    {
        if (Group is null) return;

        (_before, _after) = Group.PairAroundHandle(this);
        if (_before is null || _after is null) return;

        _groupPx = await MeasureGroupAsync();
        if (_groupPx <= 0) return;

        _dragging = true;
        _last = IsVertical ? e.ClientY : e.ClientX;
    }

    private void OnPointerMove(PointerEventArgs e)
    {
        if (!_dragging || Group is null || _before is null || _after is null) return;

        var pos = IsVertical ? e.ClientY : e.ClientX;
        var deltaPx = pos - _last;
        if (deltaPx == 0) return;
        _last = pos;

        var deltaPct = deltaPx / _groupPx * 100.0;
        Group.Resize(_before, _after, deltaPct);
    }

    private void OnPointerUp(PointerEventArgs e)
    {
        if (!_dragging) return;
        _dragging = false;
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (Group is null) return;
        var (before, after) = Group.PairAroundHandle(this);
        if (before is null || after is null) return;

        // Keyboard resize in fixed steps (react-resizable-panels arrow-key model).
        const double step = 5;
        var d = e.Key switch
        {
            "ArrowLeft" when !IsVertical => -step,
            "ArrowRight" when !IsVertical => step,
            "ArrowUp" when IsVertical => -step,
            "ArrowDown" when IsVertical => step,
            _ => 0.0,
        };
        if (d != 0) Group.Resize(before, after, d);
    }

    private const string ModulePath = "./_content/Navius.Primitives/navius-interop.js";
    private const string VendoredModulePath = "./navius-interop.js";

    // Package mode serves the engine under _content/Navius.Primitives/ (the RCL static web
    // assets). Vendored mode (the registry CLI) copies navius-interop.js into the app's own
    // wwwroot at the root. Try the package path first; on import failure fall back to the
    // vendored path, letting a genuine failure of that import propagate to the caller.
    private static async Task<IJSObjectReference> ImportModuleAsync(IJSRuntime js)
    {
        try
        {
            return await js.InvokeAsync<IJSObjectReference>("import", ModulePath);
        }
        catch (JSException)
        {
            return await js.InvokeAsync<IJSObjectReference>("import", VendoredModulePath);
        }
    }

    private async Task<double> MeasureGroupAsync()
    {
        try
        {
            _module ??= await ImportModuleAsync(JS);
            var rect = await _module.InvokeAsync<DomRect>("getRect", Group!.Element);
            return IsVertical ? rect.Height : rect.Width;
        }
        catch
        {
            return 0;
        }
    }

    private const string Base =
        "relative flex w-px items-center justify-center bg-border " +
        "after:absolute after:inset-y-0 after:left-1/2 after:w-1 after:-translate-x-1/2 " +
        "focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring focus-visible:ring-offset-1 " +
        "data-[panel-group-direction=vertical]:h-px data-[panel-group-direction=vertical]:w-full " +
        "data-[panel-group-direction=vertical]:after:left-0 data-[panel-group-direction=vertical]:after:h-1 " +
        "data-[panel-group-direction=vertical]:after:w-full data-[panel-group-direction=vertical]:after:-translate-y-1/2 " +
        "data-[panel-group-direction=vertical]:after:translate-x-0 [&[data-panel-group-direction=vertical]>div]:rotate-90 " +
        "cursor-col-resize data-[panel-group-direction=vertical]:cursor-row-resize select-none touch-none";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));

    public async ValueTask DisposeAsync()
    {
        Group?.UnregisterHandle(this);
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
            catch (JSException) { }
        }
    }

    private record DomRect(double X, double Y, double Width, double Height,
                           double Top, double Right, double Bottom, double Left);
}
