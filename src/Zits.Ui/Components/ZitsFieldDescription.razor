@namespace Zits.Ui

@* Muted helper text for a Field. *@
<p data-slot="field-description" @attributes="Attributes" class="@Css">@ChildContent</p>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "text-muted-foreground text-sm leading-normal font-normal group-data-[invalid=true]/field:text-destructive [&>a]:underline [&>a]:underline-offset-4";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));
}
