@namespace Zits.Ui
<div @attributes="Attributes" class="@Cn.Class("flex w-fit items-center gap-2 text-sm font-medium leading-snug", Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
