@namespace Zits.Ui

@* Timeline item description, the supporting copy under the title. *@

<p data-navius-timeline-description @attributes="Attributes" class="@DescriptionClass">@ChildContent</p>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "text-sm text-muted-foreground";

    private string DescriptionClass => Cn.Class(Base, Cn.UserClass(Attributes));
}
