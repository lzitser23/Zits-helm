@namespace Zits.Ui
@using Navius.Primitives.Components.MaskedInput

@*
    MaskedInput = the headless NaviusMaskedInput + the standard Input skin. Controlled/uncontrolled
    is owned HERE (the ZitsCalendar discipline): the wrapper keeps its own _value mirror seeded
    from DefaultValue when uncontrolled, always feeds the brain a controlled value, and only adopts
    the consumer's Value when it was actually supplied, so it never force-forwards a stale param.
*@

<NaviusMaskedInput Mask="@Mask"
                   Value="@_value"
                   ValueChanged="OnValueChangedAsync"
                   Placeholder="Placeholder"
                   Lazy="Lazy"
                   Disabled="Disabled"
                   Invalid="Invalid"
                   @attributes="Cn.Merge(Attributes, Base)" />

@code {
    [Parameter] public string Mask { get; set; } = "";

    /// <summary>Controlled masked value. Use <c>@bind-Value</c>.</summary>
    [Parameter] public string? Value { get; set; }

    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>Uncontrolled initial value.</summary>
    [Parameter] public string? DefaultValue { get; set; }

    /// <summary>The char shown for empty slots (e.g. <c>_</c>).</summary>
    [Parameter] public char? Placeholder { get; set; }

    [Parameter] public bool Lazy { get; set; } = true;

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public bool Invalid { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private string? _value;
    private bool _valueSet;
    private bool _initialized;

    private const string Base =
        "flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50 data-[invalid]:border-destructive data-[invalid]:ring-destructive";

    public override Task SetParametersAsync(ParameterView parameters)
    {
        _valueSet = parameters.TryGetValue<string?>(nameof(Value), out _);
        return base.SetParametersAsync(parameters);
    }

    protected override void OnParametersSet()
    {
        if (!_initialized)
        {
            _value = _valueSet ? Value : DefaultValue;
            _initialized = true;
            return;
        }

        if (_valueSet)
        {
            _value = Value;
        }
    }

    private async Task OnValueChangedAsync(string v)
    {
        if (!_valueSet)
        {
            _value = v;
        }

        await ValueChanged.InvokeAsync(v);
    }
}
