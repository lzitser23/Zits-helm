@namespace Zits.Ui
@implements IDisposable

@*
    A labelled section of items. The whole group (heading included) hides when none of
    its items match the current query.
*@

<CascadingValue Value="this" IsFixed="true">
    <div @attributes="Attributes" class="@Css" role="group" hidden="@(!HasVisibleItems)">
        @if (!string.IsNullOrEmpty(Heading))
        {
            <div cmdk-group-heading="" class="px-2 py-1.5 text-xs font-medium text-muted-foreground">@Heading</div>
        }
        @ChildContent
    </div>
</CascadingValue>

@code {
    [CascadingParameter] private ZitsCommand? _command { get; set; }

    [Parameter] public string? Heading { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "overflow-hidden p-1 text-foreground [&_[cmdk-group-heading]]:px-2 [&_[cmdk-group-heading]]:py-1.5 [&_[cmdk-group-heading]]:text-xs [&_[cmdk-group-heading]]:font-medium [&_[cmdk-group-heading]]:text-muted-foreground";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));

    private readonly HashSet<ZitsCommandItem> _items = new();

    internal void Register(ZitsCommandItem item) => _items.Add(item);
    internal void Unregister(ZitsCommandItem item) => _items.Remove(item);

    private bool HasVisibleItems => _items.Count == 0 || _items.Any(i => i.Matches);

    protected override void OnInitialized() => _command?.OnFilterChanged(OnFilterChanged);

    private void OnFilterChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => _command?.OffFilterChanged(OnFilterChanged);
}
