@namespace Zits.Ui

@* Decorative icon slot for a marker (hard-coded aria-hidden). Put a spinner here for
   in-progress status. *@
<span data-slot="marker-icon" aria-hidden="true" @attributes="Attributes" class="@Css">@ChildContent</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "size-4 shrink-0 [&_svg:not([class*='size-'])]:size-4";

    private string Css => Cn.Class(Base, Cn.UserClass(Attributes));
}
