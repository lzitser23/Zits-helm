@namespace Zits.Ui
@using Navius.Primitives.Components.ContextMenu

@* Root of the context menu over the Navius ContextMenu primitive. Renders no DOM. *@
<NaviusContextMenu Open="Open" OpenChanged="OpenChanged" DefaultOpen="DefaultOpen">@ChildContent</NaviusContextMenu>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public bool DefaultOpen { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
