@namespace Zits.Ui
@* The body of a sidebar group (usually holds a ZitsSidebarMenu). *@
<div data-sidebar="group-content" @attributes="Attributes" class="@Cn.Class("w-full text-sm", Cn.UserClass(Attributes))">@ChildContent</div>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
