@namespace Zits.Ui
@using Navius.Primitives.Components.Collapsible

@* Styled disclosure over the Navius Collapsible primitive. The Collapsible
   root is an unstyled passthrough; consumer classes/attributes are forwarded.
   Open is forwarded to the primitive ONLY when the consumer set it, so the uncontrolled
   DefaultOpen path stays live (the always-controlled wart fix). *@
<NaviusCollapsible OpenChanged="OpenChanged" DefaultOpen="DefaultOpen"
                   Disabled="Disabled" @attributes="Forwarded">
    @ChildContent
</NaviusCollapsible>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public bool DefaultOpen { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private bool _openSet;

    public override Task SetParametersAsync(ParameterView parameters)
    {
        _openSet = parameters.TryGetValue<bool>(nameof(Open), out _);
        return base.SetParametersAsync(parameters);
    }

    // Forward the consumer's splat plus Open only when the consumer supplied it.
    private IReadOnlyDictionary<string, object> Forwarded
    {
        get
        {
            var merged = Attributes is null
                ? new Dictionary<string, object>()
                : new Dictionary<string, object>(Attributes);
            if (_openSet)
            {
                merged["Open"] = Open;
            }

            return merged;
        }
    }
}
