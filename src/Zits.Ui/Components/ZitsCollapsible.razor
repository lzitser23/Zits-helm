@namespace Zits.Ui
@using Navius.Primitives.Components.Collapsible

@* Styled disclosure over the Navius Collapsible primitive. The Collapsible
   root is an unstyled passthrough; consumer classes/attributes are forwarded. *@
<NaviusCollapsible Open="Open" OpenChanged="OpenChanged" DefaultOpen="DefaultOpen"
                   Disabled="Disabled" @attributes="Attributes">
    @ChildContent
</NaviusCollapsible>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public bool DefaultOpen { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
