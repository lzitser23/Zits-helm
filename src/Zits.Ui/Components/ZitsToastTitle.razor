@namespace Zits.Ui
@using Navius.Primitives.Components.Toast

@* The toast title (drives aria-labelledby). *@
<NaviusToastTitle @attributes="Cn.Merge(Attributes, Base)">@ChildContent</NaviusToastTitle>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private const string Base = "text-sm font-semibold";
}
