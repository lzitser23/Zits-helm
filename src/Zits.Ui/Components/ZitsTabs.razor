@namespace Zits.Ui
@* Styled tabs over the Navius Tabs primitive (roving selection, activation mode). *@
<NaviusTabs Value="@Value" ValueChanged="ValueChanged" DefaultValue="@DefaultValue"
            Orientation="@Orientation" ActivationMode="@ActivationMode"
            @attributes="Cn.Merge(Attributes, Base)">@ChildContent</NaviusTabs>
@code {
    private const string Base = "flex flex-col gap-2";
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? DefaultValue { get; set; }
    [Parameter] public string Orientation { get; set; } = "horizontal";
    [Parameter] public string ActivationMode { get; set; } = "automatic";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
