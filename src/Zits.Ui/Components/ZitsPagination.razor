@namespace Zits.Ui
@*
    Pagination — the navigation landmark wrapping the page list. Pure Tailwind,
    no brain needed. Compose with ZitsPaginationContent / ZitsPaginationItem /
    ZitsPaginationLink / ZitsPaginationPrevious / ZitsPaginationNext / ZitsPaginationEllipsis.
*@
<nav role="navigation" aria-label="pagination" @attributes="Attributes" class="@Cn.Class("mx-auto flex w-full justify-center", Cn.UserClass(Attributes))">@ChildContent</nav>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }
}
