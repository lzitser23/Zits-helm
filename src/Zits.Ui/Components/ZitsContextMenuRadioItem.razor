@namespace Zits.Ui
@using Navius.Primitives.Components.ContextMenu

@* A radio menu item with a left-aligned dot indicator. *@
<NaviusContextMenuRadioItem Value="@Value" OnSelect="OnSelect" Disabled="Disabled" TextValue="@TextValue"
                            @attributes="Cn.Merge(Attributes, Base)">
    <span class="absolute left-2 flex h-3.5 w-3.5 items-center justify-center">
        <NaviusContextMenuItemIndicator>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-2 w-2 fill-current">
                <circle cx="12" cy="12" r="10" />
            </svg>
        </NaviusContextMenuItemIndicator>
    </span>
    @ChildContent
</NaviusContextMenuRadioItem>

@code {
    [Parameter] public string Value { get; set; } = default!;
    [Parameter] public EventCallback<Navius.Primitives.Common.NaviusSelectEventArgs> OnSelect { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? TextValue { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? Attributes { get; set; }

    private const string Base =
        "relative flex cursor-default select-none items-center rounded-sm py-1.5 pl-8 pr-2 text-sm outline-none transition-colors focus:bg-accent focus:text-accent-foreground data-[highlighted]:bg-accent data-[highlighted]:text-accent-foreground data-[disabled]:pointer-events-none data-[disabled]:opacity-50";
}
