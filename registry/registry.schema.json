{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lzitser23/Zits-helm/registry/registry.schema.json",
  "title": "Navius component registry",
  "description": "Schema for the Navius copy-paste component registry manifest (registry.json).",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "homepage", "items"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Relative path to this schema, for editor validation."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "The registry name."
    },
    "homepage": {
      "type": "string",
      "minLength": 1,
      "description": "The registry homepage URL."
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/item" }
    }
  },
  "$defs": {
    "registryType": {
      "type": "string",
      "enum": ["registry:ui", "registry:lib"],
      "description": "Item kind: a UI component (registry:ui) or a plain library (registry:lib)."
    },
    "fileType": {
      "type": "string",
      "enum": ["registry:ui", "registry:lib", "registry:file"],
      "description": "File kind: registry:ui / registry:lib source, or registry:file for a verbatim asset (JS/CSS/_Imports/templates)."
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "title", "dependencies", "registryDependencies", "files"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "Kebab-case item id used by `navius add <name>`."
        },
        "type": { "$ref": "#/$defs/registryType" },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "External (NuGet) package dependencies."
        },
        "registryDependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Names of other registry items this item requires."
        },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/file" },
          "description": "Files copied into the consumer project. May be empty for an alias item whose payload ships via registryDependencies."
        }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "type", "target"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Source path, relative to the registry repo root (may reference the sibling brain repo via ../navius/)."
        },
        "type": { "$ref": "#/$defs/fileType" },
        "target": {
          "type": "string",
          "minLength": 1,
          "description": "Destination path (POSIX-separated) inside the consumer project."
        }
      }
    }
  }
}
